# ============================================================
# АОИ-Web — пример файла окружения. Скопируйте в .env
# ============================================================

# Секрет для подписи JWT (обязательно заменить в продакшне!)
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# Время жизни токена доступа (в минутах). ТЗ: не более 8 часов.
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Строка подключения к БД. По умолчанию — SQLite для dev-режима.
# Для продакшна: postgresql+psycopg2://aoi:aoi@localhost:5432/aoi
DATABASE_URL=sqlite:///./aoi.db

# Путь к весам модели YOLOv8. Если файла нет — используется fallback-детектор.
MODEL_WEIGHTS_PATH=models/aoi_unified.pt

# Порог достоверности детекции
DETECTION_CONF_THRESHOLD=0.25
DETECTION_IOU_THRESHOLD=0.45

# --- Предобработка кадра перед YOLO (ТЗ п. 3.x: без Gaussian, только edge-preserving) ---
# Включить цепочку apply_detection_preprocess перед Detector.predict
# DETECTION_PREPROCESS_ENABLED=false
# Шум: none | bilateral | median (Gaussian в коде не используется)
# PREPROCESS_NOISE_FILTER=none
# PREPROCESS_BILATERAL_D=7
# PREPROCESS_BILATERAL_SIGMA_COLOR=75
# PREPROCESS_BILATERAL_SIGMA_SPACE=75
# PREPROCESS_MEDIAN_KSIZE=3
# Освещение: none | clahe (YCrCb) | tophat_lab (L в Lab)
# PREPROCESS_ILLUMINATION=none
# PREPROCESS_CLAHE_CLIP_LIMIT=2.0
# PREPROCESS_CLAHE_TILE_GRID=8
# PREPROCESS_TOPHAT_KERNEL_SIZE=31
# Опционально: JSON калибровки cv2 (camera_matrix, dist_coeffs) + undistort
# PREPROCESS_LENS_UNDISTORT=false
# DETECTION_CALIBRATION_JSON=

# Сверка детекций YOLO с regions Golden Board (после ECC-выравнивания)
# GOLDEN_REGION_CHECK_ENABLED=true
# GOLDEN_REGION_MIN_IOU=0.2
# GOLDEN_REGION_TOLERANCE_PX=12

# Каталог для хранения изображений и визуализаций
STORAGE_DIR=storage

# Максимальный размер загружаемого изображения, Мбайт (ТЗ: 15 Мбайт)
MAX_UPLOAD_MB=15

# Параметры блокировки учётной записи (ТЗ: 5 попыток / 15 минут)
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Публичный базовый URL для ссылок на телефон (/phone?device=…&token=…).
# Обязательно для доступа с телефона по Wi‑Fi: IP вашего ПК в LAN, тот же порт и схема что у HTTPS.
# Пример: PUBLIC_BASE_URL=https://192.168.1.10:8000
# PUBLIC_BASE_URL=
# Если пусто: run.bat и run_https.bat сами выставляют PUBLIC_BASE_URL на IP в LAN (этот же порт).

# ESP32: настройки на вкладке «Инспекция» (БД). Ниже — только начальные значения при первом запуске.
# ESP32_BASE_URL=http://192.168.0.50
# HARDWARE_TRANSPORT=http

# Bcrypt cost factor (ТЗ: не ниже 12)
BCRYPT_ROUNDS=12

# Журнал: путь к лог-файлу
LOG_FILE=logs/aoi.log
LOG_LEVEL=INFO

# Первичный администратор (создаётся скриптом init_db.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_FULL_NAME=Администратор системы
